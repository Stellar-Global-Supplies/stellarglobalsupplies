{
  "name": "s3-cleanup",
  "version": "1.0.0",
  "description": "S3 cleanup Lambda - deletes old files with per-bucket retention (7d for cf-logs, 2d for others)",
  "main": "dist/handler.js",
  "scripts": {
    "build": "esbuild src/handler.ts --bundle --minify --sourcemap --target=node22 --platform=node --outfile=dist/handler.js --format=cjs --external:aws-sdk",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.3"
  }
}